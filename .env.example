# =========================================================
# SCORE STORE — Environment Variables (.env.example)
# NO subas secretos al repo. Configúralos en Netlify:
# Site settings -> Environment variables
# =========================================================

# URL base (Netlify la pone como URL / DEPLOY_PRIME_URL, pero puedes forzarla aquí)
SITE_URL=https://scorestore.netlify.app

# -------------------------
# Stripe (Checkout + Webhook)
# -------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# 1 = habilita OXXO en Checkout (si tu cuenta Stripe lo tiene activado)
STRIPE_ENABLE_OXXO=0

# -------------------------
# Envía.com (cotizador + guía)
# -------------------------
# Ambiente: prod | sandbox
ENVIA_ENV=prod
ENVIA_API_KEY=

# Opcional: sobre-escribe URLs si necesitas algo especial
# ENVIA_API_URL=https://api.envia.com
# ENVIA_GEOCODES_URL=https://geocodes.envia.com

# Carriers default (según lo que tengas activado en tu cuenta Envía)
ENVIA_MX_DEFAULT_CARRIER=dhl
ENVIA_US_DEFAULT_CARRIER=usps

# Si Envía te regresa tarifas US en USD y quieres convertir a MXN:
ENVIA_FORCE_USD_TO_MXN=0
FX_USD_TO_MXN=18

# Opcional: proteger el webhook (si configuras Envía para enviar token)
ENVIA_WEBHOOK_TOKEN=

# -------------------------
# Origen (remitente) para Envía
# -------------------------
# MX
ORIGIN_MX_NAME=Score Store MX
ORIGIN_MX_COMPANY=Único Uniformes
ORIGIN_MX_EMAIL=
ORIGIN_MX_PHONE=
ORIGIN_MX_STREET=
ORIGIN_MX_NUMBER=
ORIGIN_MX_DISTRICT=
ORIGIN_MX_CITY=Tijuana
ORIGIN_MX_STATE=Baja California
ORIGIN_MX_POSTAL=22614
ORIGIN_MX_RFC=BAJ220613P51
ORIGIN_MX_REFERENCE=

# US (si usas origen en USA; si no, deja defaults)
ORIGIN_US_NAME=Score Store US
ORIGIN_US_COMPANY=Score Store
ORIGIN_US_EMAIL=
ORIGIN_US_PHONE=
ORIGIN_US_STREET=
ORIGIN_US_NUMBER=
ORIGIN_US_DISTRICT=
ORIGIN_US_CITY=San Diego
ORIGIN_US_STATE=CA
ORIGIN_US_POSTAL=92101
ORIGIN_US_REFERENCE=

# -------------------------
# Paquete (peso/dimensiones) para Envía
# -------------------------
# MX (KG / CM)
PACK_WEIGHT_KG=1
PACK_L_CM=30
PACK_W_CM=25
PACK_H_CM=10

# US (LB / IN)
PACK_WEIGHT_LB=1
PACK_L_IN=11
PACK_W_IN=15
PACK_H_IN=20

# -------------------------
# Fallback de envío (si Envía falla)
# -------------------------
FALLBACK_MX_PRICE_MXN=250
FALLBACK_US_PRICE_MXN=850
FALLBACK_PER_ITEM_MXN=50

# -------------------------
# Cliente (fallback para cotización Envía)
# -------------------------
DEFAULT_CUSTOMER_NAME=Cliente
DEFAULT_CUSTOMER_EMAIL=no-reply@scorestore.com
DEFAULT_CUSTOMER_PHONE=0000000000
DEFAULT_CUSTOMER_DISTRICT=Centro

# Contacto general (usado como fallback)
FACTORY_EMAIL=

# -------------------------
# Telegram (opcional) — alertas de pago / tracking
# -------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# -------------------------
# Supabase (orders + shipping_labels para UnicOs admin)
# -------------------------
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# -------------------------
# Gemini (Score AI)
# -------------------------
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# -------------------------
# Meta Pixel / verificación
# -------------------------
META_PIXEL_ID=
FACEBOOK_DOMAIN_VERIFICATION=